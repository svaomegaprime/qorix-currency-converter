<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Message</title>
  </head>
  <body style="margin:0; padding:20px; background-color:#f9fafb; font-family:Arial, sans-serif; color:#333;">
    
    <div style="max-width:600px; margin:0 auto; background:#ffffff; padding:24px; border-radius:6px; border:1px solid #e5e7eb;">
      
      <h2 style="margin-top:0; font-size:20px; color:#111827;">
        Customer Data Request
      </h2>

      <p style="font-size:15px; line-height:1.6; color:#4b5563;">
        <%= data.message %>
      </p>

      <% if (buttonUrl) { %>
        <div style="margin-top:24px;">
          <a 
            href="<%= buttonUrl %>" 
            style="display:inline-block; padding:10px 16px; background:#111827; color:#ffffff; text-decoration:none; border-radius:4px; font-size:14px;"
          >
            Visit Store
          </a>
        </div>
      <% } %>

    </div>

  </body>
</html>

